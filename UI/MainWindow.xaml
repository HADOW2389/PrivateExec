<Window x:Class="PrivateExec.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrivateExec" Height="620" Width="940"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResize"
        MinWidth="700" MinHeight="480">

    <Window.Resources>
        <!-- Colours -->
        <SolidColorBrush x:Key="Bg"         Color="#0A0A0A"/>
        <SolidColorBrush x:Key="BgCard"     Color="#111111"/>
        <SolidColorBrush x:Key="BgHover"    Color="#181818"/>
        <SolidColorBrush x:Key="Border"     Color="#1E1E1E"/>
        <SolidColorBrush x:Key="Accent"     Color="#5865F2"/>
        <SolidColorBrush x:Key="AccentDim"  Color="#3D4AC8"/>
        <SolidColorBrush x:Key="TextPri"    Color="#F2F2F2"/>
        <SolidColorBrush x:Key="TextSec"    Color="#808080"/>
        <SolidColorBrush x:Key="Green"      Color="#3BA55D"/>
        <SolidColorBrush x:Key="Red"        Color="#ED4245"/>
        <SolidColorBrush x:Key="Orange"     Color="#FAA61A"/>

        <!-- Fonts -->
        <FontFamily x:Key="Mono">Consolas, Courier New</FontFamily>

        <!-- Sidebar button style -->
        <Style x:Key="SideBtn" TargetType="Border">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="CornerRadius"     Value="6"/>
            <Setter Property="Padding"          Value="10,8"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Margin"           Value="6,2"/>
        </Style>

        <!-- Inject button -->
        <Style x:Key="InjectBtn" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"       Value="#FFFFFF"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="18,9"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDim}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small action button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"       Value="#1A1A1A"/>
            <Setter Property="Foreground"       Value="{StaticResource TextSec}"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Padding"          Value="12,7"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPri}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="4"/>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

    </Window.Resources>

    <!-- Outer shadow border -->
    <Border CornerRadius="12" Background="{StaticResource Bg}"
            BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>   <!-- Titlebar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="28"/>   <!-- Status bar -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/> <!-- Sidebar icons -->
                <ColumnDefinition Width="*"/>  <!-- Main content -->
            </Grid.ColumnDefinitions>

            <!-- ══ TITLEBAR ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="#0D0D0D" CornerRadius="12,12,0,0"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="Titlebar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo + name -->
                    <StackPanel Orientation="Horizontal" Margin="14,0,0,0"
                                VerticalAlignment="Center">
                        <Ellipse Width="20" Height="20" Margin="0,0,8,0">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#5865F2" Offset="0"/>
                                    <GradientStop Color="#3D4AC8" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="PrivateExec" Foreground="{StaticResource TextPri}"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="VersionTag" Text=" v1.0" Foreground="{StaticResource TextSec}"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Chrome buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="MinBtn" Click="MinBtn_Click" Width="32" Height="32"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                ToolTip="Minimize">
                            <TextBlock Text="─" Foreground="{StaticResource TextSec}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="CloseBtn" Click="CloseBtn_Click" Width="32" Height="32"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                ToolTip="Close">
                            <TextBlock Text="✕" Foreground="{StaticResource TextSec}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#C0392B"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ SIDEBAR ════════════════════════════════════════════════════ -->
            <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                    Background="#0D0D0D"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,8,0,0">

                    <!-- Home -->
                    <Border x:Name="SideHome" Style="{StaticResource SideBtn}"
                            MouseLeftButtonDown="SideHome_Click" ToolTip="Editor">
                        <TextBlock Text="⌨" FontSize="18" HorizontalAlignment="Center"
                                   Foreground="{StaticResource Accent}"/>
                    </Border>

                    <!-- Scripts -->
                    <Border x:Name="SideScripts" Style="{StaticResource SideBtn}"
                            MouseLeftButtonDown="SideScripts_Click" ToolTip="Scripts">
                        <TextBlock Text="📄" FontSize="18" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextSec}"/>
                    </Border>

                    <!-- Settings -->
                    <Border x:Name="SideSettings" Style="{StaticResource SideBtn}"
                            MouseLeftButtonDown="SideSettings_Click" ToolTip="Settings">
                        <TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextSec}"/>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ══ MAIN CONTENT ═══════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Grid.Column="1">

                <!-- PAGE: Editor -->
                <Grid x:Name="PageEditor" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>  <!-- tab bar -->
                        <RowDefinition Height="*"/>   <!-- editor body -->
                        <RowDefinition Height="Auto"/><!-- action bar -->
                    </Grid.RowDefinitions>

                    <!-- Tab bar -->
                    <Border Grid.Row="0" Background="#0E0E0E"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="TabBar" Orientation="Horizontal" Margin="6,0,0,0"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Editor area (Monaco WebView placeholder) -->
                    <Border Grid.Row="1" Background="#0C0C0C">
                        <!-- Monaco editor or fallback TextBox -->
                        <TextBox x:Name="ScriptEditor"
                                 Background="#0C0C0C"
                                 Foreground="#C9D1D9"
                                 FontFamily="{StaticResource Mono}"
                                 FontSize="13"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 Padding="14,10"
                                 CaretBrush="{StaticResource Accent}"
                                 SelectionBrush="{StaticResource AccentDim}"
                                 Text="-- PrivateExec | version-8884371d30284041&#x0a;-- 100% UNC | Undetected&#x0a;&#x0a;print(&quot;Hello from PrivateExec!&quot;)"/>
                    </Border>

                    <!-- Action bar -->
                    <Border Grid.Row="2" Background="#0E0E0E"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                            Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: small buttons -->
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ActionBtn}" Content="Clear"
                                        Margin="0,0,6,0" Click="ClearBtn_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Open File"
                                        Margin="0,0,6,0" Click="OpenFileBtn_Click"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Save"
                                        Click="SaveBtn_Click"/>
                            </StackPanel>

                            <!-- Right: Execute + Inject -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="InjectBtn" Style="{StaticResource InjectBtn}"
                                        Content="Inject" Click="InjectBtn_Click"
                                        Width="90" Margin="0,0,8,0"/>
                                <Button x:Name="ExecBtn" Style="{StaticResource InjectBtn}"
                                        Content="Execute" Click="ExecBtn_Click"
                                        Width="90"
                                        Background="{StaticResource Green}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- PAGE: Scripts -->
                <Grid x:Name="PageScripts" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0E0E0E"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                            Padding="14,0">
                        <TextBlock Text="Scripts" Foreground="{StaticResource TextPri}"
                                   FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="10">
                        <StackPanel x:Name="ScriptList"/>
                    </ScrollViewer>
                </Grid>

                <!-- PAGE: Settings -->
                <Grid x:Name="PageSettings" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0E0E0E"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                            Padding="14,0">
                        <TextBlock Text="Settings" Foreground="{StaticResource TextPri}"
                                   FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="18">
                        <StackPanel>

                            <!-- Unlock FPS toggle -->
                            <Border Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    CornerRadius="8" Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Unlock FPS" Foreground="{StaticResource TextPri}"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="Set TaskScheduler maxFPS to 0 (uncapped)"
                                                   Foreground="{StaticResource TextSec}" FontSize="11"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ToggleFPS" Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Checked="ToggleFPS_Changed"
                                              Unchecked="ToggleFPS_Changed"/>
                                </Grid>
                            </Border>

                            <!-- Auto inject toggle -->
                            <Border Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    CornerRadius="8" Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Auto Inject" Foreground="{StaticResource TextPri}"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="Automatically inject when Roblox is detected"
                                                   Foreground="{StaticResource TextSec}" FontSize="11"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ToggleAutoInject" Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Checked="ToggleAutoInject_Changed"
                                              Unchecked="ToggleAutoInject_Changed"/>
                                </Grid>
                            </Border>

                            <!-- Topmost toggle -->
                            <Border Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    CornerRadius="8" Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Always on Top" Foreground="{StaticResource TextPri}"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="Keep window above other applications"
                                                   Foreground="{StaticResource TextSec}" FontSize="11"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ToggleTopmost" Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Checked="ToggleTopmost_Changed"
                                              Unchecked="ToggleTopmost_Changed"/>
                                </Grid>
                            </Border>

                            <!-- Version info -->
                            <Border Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    CornerRadius="8" Padding="14,12">
                                <StackPanel>
                                    <TextBlock Text="PrivateExec v1.0" Foreground="{StaticResource TextPri}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Roblox version-8884371d30284041"
                                               Foreground="{StaticResource TextSec}" FontSize="11"/>
                                    <TextBlock Text="100% UNC | Manual Map | Indirect Syscalls"
                                               Foreground="{StaticResource TextSec}" FontSize="11"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>

            <!-- ══ STATUS BAR ════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Grid.ColumnSpan="2"
                    Background="#0D0D0D" CornerRadius="0,0,12,12"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: status -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="7" Height="7" Margin="0,0,8,0">
                            <Ellipse.Fill>
                                <SolidColorBrush x:Name="StatusDotColor" Color="#808080"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock x:Name="StatusText" Text="Not Attached"
                                   Foreground="{StaticResource TextSec}" FontSize="11"/>
                    </StackPanel>

                    <!-- Right: process info -->
                    <TextBlock x:Name="ProcInfo" Grid.Column="1"
                               Foreground="{StaticResource TextSec}" FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>